{
  "defaultMode": "default",
  "enabledMcpjsonServers": [
    "dotto-notion"
  ],
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "codex@openai-codex": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(mise setup)",
      "Edit",
      "Read",
      "Write",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:gist.githubusercontent.com)",
      "WebFetch(domain:objects.githubusercontent.com)",
      "mcp__dotto-notion__notion-fetch",
      "mcp__dotto-notion__notion-get-comments",
      "mcp__dotto-notion__notion-get-teams",
      "mcp__dotto-notion__notion-get-users",
      "mcp__dotto-notion__notion-search",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [
      "Bash(bash *)",
      "Bash(brew install *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(env *)",
      "Bash(eval *)",
      "Bash(export *)",
      "Bash(firebase *)",
      "Bash(gcloud *)",
      "Bash(git push * --delete *)",
      "Bash(git push * --force *)",
      "Bash(git push * -d *)",
      "Bash(git push * -f *)",
      "Bash(history:*)",
      "Bash(rm -rf *)",
      "Bash(sh *)",
      "Bash(source:*)",
      "Bash(sudo:*)",
      "Bash(telnet:*)",
      "Bash(wget *)",
      "Bash(zsh *)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.envrc)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Edit(**/.codex/config.toml)",
      "Read(**/*.cer)",
      "Read(**/*.cert)",
      "Read(**/*.jks)",
      "Read(**/*.key)",
      "Read(**/*.keystore)",
      "Read(**/*.p8)",
      "Read(**/*.p12)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.envrc)",
      "Write(**/.claude/settings.json)",
      "Write(**/.claude/settings.local.json)",
      "Write(**/.codex/config.toml)"
    ],
    "ask": [
      "Bash(rm *)",
      "mcp__dotto-notion__notion-create-comment",
      "mcp__dotto-notion__notion-create-database",
      "mcp__dotto-notion__notion-create-pages",
      "mcp__dotto-notion__notion-create-view",
      "mcp__dotto-notion__notion-duplicate-page",
      "mcp__dotto-notion__notion-move-pages",
      "mcp__dotto-notion__notion-update-data-source",
      "mcp__dotto-notion__notion-update-page",
      "mcp__dotto-notion__notion-update-view"
    ]
  }
}
